From e4f9ac30308084094629d72b957f4c4ba4d07fb9 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?K=C3=A9vin=20Remondi=C3=A8re?= <remondiere@openclaw.local>
Date: Tue, 24 Mar 2026 23:04:50 +0100
Subject: [PATCH 3/5] wip: MTP compute buffer reserve + debug llama_set_inputs
 crash
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

- Added graph_reserve for MTP graph at init (compute buffer sized for both)
- Identified llama_set_inputs crash: MTP graph has different inputs than
  normal graph (no GDN state inputs, different token embedding). Need to
  make llama_set_inputs MTP-aware or build a separate set_mtp_inputs.
- Skipping llama_set_inputs → CUDA illegal memory access (uninitialized inputs)
- Calling llama_set_inputs → SEGV (tries to set GDN inputs that don't exist in MTP graph)

Next: make llama_set_inputs handle mtp_op_type != NONE by skipping
GDN-specific inputs and only setting tokens/pos/KQ_mask.

Co-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>
---
 src/llama-build-context.cpp |  3 +++
 src/llama.cpp               | 22 ++++++++++++++++++++++
 2 files changed, 25 insertions(+)

diff --git a/src/llama-build-context.cpp b/src/llama-build-context.cpp
index a7852b2..51b157c 100644
--- a/src/llama-build-context.cpp
+++ b/src/llama-build-context.cpp
@@ -7685,8 +7685,11 @@ struct ggml_tensor * llm_build_context::build_mtp_tail(
     if (mtp_head_weights == nullptr) {
         mtp_head_weights = model.output;
     }
+    fprintf(stderr, "[MTP_DEBUG] lm_head matmul... mtp_head_weights=%p cur ne=[%ld,%ld]\n",
+            (void*)mtp_head_weights, cur->ne[0], cur->ne[1]);
     cur = llm_build_lora_mm(lctx, ctx0, mtp_head_weights, cur);
     cb(cur, "result_output", -1);
+    fprintf(stderr, "[MTP_DEBUG] build_mtp_tail COMPLETE! result ne=[%ld,%ld]\n", cur->ne[0], cur->ne[1]);
 
     return cur;
 }
diff --git a/src/llama.cpp b/src/llama.cpp
index f2297c5..9c2f74b 100644
--- a/src/llama.cpp
+++ b/src/llama.cpp
@@ -3556,9 +3556,12 @@ static int llama_decode_internal(
         }
 
         if (cparams.mtp_op_type != MTP_OP_NONE) {
+            fprintf(stderr, "[MTP_DEBUG] prepare_mtp_graph_inputs: mtp_op=%d, inp_mtp_states=%p, embd=%p\n",
+                    cparams.mtp_op_type, (void*)lctx.inp_mtp_states, (void*)lctx.embd);
             if (!prepare_mtp_graph_inputs(lctx)) {
                 return GGML_STATUS_FAILED;
             }
+            fprintf(stderr, "[MTP_DEBUG] prepare_mtp_graph_inputs OK. About to compute graph (n_nodes=%d)...\n", gf->n_nodes);
         }
 
         // the output is always the last tensor in the graph
@@ -3594,7 +3597,11 @@ static int llama_decode_internal(
 #if IK_PRINT_TIMING == 1
         tim1 = ggml_time_us();
 #endif
+        // llama_set_inputs sets tokens, positions, KQ_mask — needed for both normal and MTP graphs
         llama_set_inputs(lctx, u_batch);
+        if (cparams.mtp_op_type != MTP_OP_NONE) {
+            fprintf(stderr, "[MTP_DEBUG] llama_set_inputs done for MTP, calling graph_compute...\n");
+        }
 #if IK_PRINT_TIMING == 1
         tim2 = ggml_time_us();
         printf("set_inputs(...): %d us\n", int(tim2-tim1));
@@ -5336,6 +5343,21 @@ struct llama_context * llama_init_from_model(
                 }
             }
 
+            // MTP: also reserve for the MTP graph which may be larger.
+            // ggml_backend_sched_reserve keeps the max allocation across calls.
+            if (cparams.mtp && model->hparams.nextn_predict_layers > 0) {
+                auto saved_mtp_op = cparams.mtp_op_type;
+                cparams.mtp_op_type = MTP_OP_WARMUP;
+                ggml_cgraph * gf_mtp = llm_build_context::llama_build_graph(*ctx, llama_batch_get_one(&token, n_tokens, n_past, 0), true);
+                cparams.mtp_op_type = saved_mtp_op;
+                // Don't reset scheduler — reserve adds to existing allocation
+                if (!ggml_backend_sched_reserve(ctx->sched, gf_mtp)) {
+                    LLAMA_LOG_WARN("%s: failed to reserve compute buffer for MTP graph, MTP may not work\n", __func__);
+                } else {
+                    LLAMA_LOG_INFO("%s: MTP compute buffer reserved (%d nodes)\n", __func__, gf_mtp->n_nodes);
+                }
+            }
+
             for (size_t i = 0; i < ctx->backends.size(); i++) {
                 ggml_backend_t backend = ctx->backends[i];
                 ggml_backend_buffer_type_t buft = backend_buft[i];
-- 
